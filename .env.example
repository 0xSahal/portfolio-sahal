# Required
MONGODB_URI=
RESEND_API_KEY=
# Where new-brief notifications land (your inbox).
CONTACT_EMAIL=
# Verified-domain sender for outbound mail, e.g. "Sahal Shaikh <hello@sahalshaikh.com>".
# Required to send the lead autoresponder; without it only the owner notification
# goes out (via Resend's sandbox sender, which can only deliver to CONTACT_EMAIL).
RESEND_FROM=

# Public (safe to expose in browser)
NEXT_PUBLIC_SITE_URL=https://sahalshaikh.com
NEXT_PUBLIC_CALENDLY_URL=
NEXT_PUBLIC_WHATSAPP_NUMBER=
# Google Analytics 4 measurement ID (e.g. G-XXXXXXXXXX). Omit to disable analytics.
NEXT_PUBLIC_GA_ID=
# Google reCAPTCHA v3 — create keys at https://www.google.com/recaptcha/admin (v3).
# Both keys are required for verification; omit either to disable reCAPTCHA in dev.
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=
RECAPTCHA_SECRET_KEY=

# Sanity (blog CMS) — projectId + dataset are public by design.
# Find them at https://www.sanity.io/manage  →  your project.
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=production
NEXT_PUBLIC_SANITY_API_VERSION=2025-01-01
# Optional: only needed later to preview unpublished drafts.
SANITY_API_READ_TOKEN=
# Optional: write token (Editor role) used only by `npm run seed:blog`.
# Create at https://www.sanity.io/manage → API → Tokens. Keep secret.
SANITY_API_WRITE_TOKEN=
# Shared secret for the /api/revalidate webhook. Set the SAME value here and in
# the Sanity GROQ webhook (Manage → API → Webhooks → Secret) so published posts
# refresh instantly. Omit to disable on-demand revalidation (hourly fallback
# still applies). Generate one with: openssl rand -hex 32
SANITY_REVALIDATE_SECRET=
